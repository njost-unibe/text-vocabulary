@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.org/occupations>
    a skos:ConceptScheme ;
    skos:prefLabel "Occupations"@en .

<https://example.org/occupations/programmer>
    a skos:Concept ;
    skos:prefLabel "Programmer"@en ;
    skos:inScheme <https://example.org/occupations> .